{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 generate.py)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Edit(output/**)",
      "Write(output/**)"
    ]
  }
}
